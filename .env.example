# Sweet Bakery Environment Configuration
# Copy this file to .env and update the values

# Database Configuration
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=sweetbakery_v2
DB_CHARSET=utf8mb4

# Application Settings
APP_NAME="Sweet Bakery"
APP_SLOGAN="Freshly Baked Every Day"
APP_URL=http://localhost/sweet-bakery
APP_ENV=development
APP_DEBUG=true

# Email Configuration (for PHPMailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="Sweet Bakery"
MAIL_FROM_ADDRESS=noreply@sweetbakery.com

# Upload Settings
MAX_UPLOAD_SIZE=2097152
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif

# Session Settings
SESSION_LIFETIME=120
SESSION_NAME=SWEET_BAKERY_SESSION
